# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ADMIN_SECRET_KEY: Secret key used to authenticate admin API endpoints.
# The SellerHub sends this key in the x-admin-key header on every admin call.
# Generate a strong random key: openssl rand -hex 32
ADMIN_SECRET_KEY="change-this-to-a-random-secret-key"

# Supabase Auth — configure for magic link login
# Leave as defaults and the app falls back to dev mode (local auth only)
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Supabase Service Role — for server-side products & orders persistence
# Paste the service_role key (NOT the anon key) from Project Settings → API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Resend API Key — for order confirmation emails (free up to 3000/month)
# Get yours at https://resend.com
# Must use a verified sending domain (or the default resend.dev sandbox in test mode)
RESEND_API_KEY="re_xxxxxxxxxxxxx"

# Cloudflare R2 Credentials — for product images & files storage
R2_ACCOUNT_ID="your-r2-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="belvia-version-1"
R2_PUBLIC_URL="https://pub-yourbucket.r2.dev"

# Web Push — VAPID Keys (generated once with: npx web-push generate-vapid-keys --json)
# Rotating these keys invalidates ALL existing push subscriptions — treat them like long-lived credentials.
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@belvia3d.com"
# Public key also exposed to the Vite frontend for PushSubscription creation
VITE_VAPID_PUBLIC_KEY="your-vapid-public-key"
